<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Andrea Diaz — Full-Stack Developer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700;800;900&family=Petit+Formal+Script&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#FAF8F3;
    --panel:#FFFFFF;
    --ink:#141311;
    --ink-soft:#524F47;
    --muted:#918D82;
    --tan:#C9A876;
    --tan-soft:#F1E6D2;
    --line:#141311;
    --line-soft:#E4DFD3;
    --black:#0B0A09;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--ink);
    font-family:'Inter',sans-serif;
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
  }
  a{color:inherit; text-decoration:none;}
  .wrap{max-width:1100px; margin:0 auto; padding:0 28px;}
  .eyebrow{
    font-family:'JetBrains Mono',monospace;
    font-size:12px; letter-spacing:0.12em; text-transform:uppercase;
    color:var(--tan); font-weight:500;
  }
  h1,h2,h3{font-family:'Playfair Display',serif; letter-spacing:-0.01em;}
  .script{font-family:'Petit Formal Script',cursive; font-weight:400;}

  /* BANNER / HERO */
  .banner{background:var(--black); color:#F4EFE4; position:relative; overflow:hidden;}
  .banner-top{
    display:flex; justify-content:space-between; align-items:center;
    padding:20px 28px; max-width:1100px; margin:0 auto;
  }
  .logo-mark{height:44px; width:auto; display:block;}
  .banner-nav{display:flex; gap:26px; font-size:12px; text-transform:uppercase; letter-spacing:0.08em; font-weight:600;}
  .banner-nav a{color:#D9D2C2; transition:color 0.15s;}
  .banner-nav a:hover{color:var(--tan);}

  .banner-body{
    display:grid; grid-template-columns:0.9fr 1.1fr; gap:44px; align-items:center;
    padding:20px 28px 56px; max-width:1100px; margin:0 auto;
  }
  .banner-photo img{width:100%; display:block;}
  .banner-text .script{font-size:26px; color:var(--tan); display:block; margin-bottom:6px;}
  .banner-text h1{font-size:clamp(38px,5.2vw,64px); font-weight:800; color:#F4EFE4; line-height:1.03; margin-bottom:10px;}
  .banner-text .role{
    font-family:'JetBrains Mono',monospace; font-size:12px; letter-spacing:0.16em; text-transform:uppercase;
    color:#C9A876; margin-bottom:22px;
  }
  .banner-text p.lede{color:#C7C1B3; font-size:15.5px; max-width:44ch; margin-bottom:26px;}
  .banner-cta{display:flex; gap:12px; flex-wrap:wrap; margin-bottom:34px;}

  .btn{
    display:inline-flex; align-items:center; gap:8px;
    padding:14px 24px; font-size:13px; font-weight:700;
    text-transform:uppercase; letter-spacing:0.05em; border-radius:2px;
    transition:all 0.15s; border:1.5px solid var(--tan);
  }
  .btn-primary{background:var(--tan); color:var(--black); border-color:var(--tan);}
  .btn-primary:hover{background:transparent; color:var(--tan);}
  .btn-ghost{background:transparent; color:#F4EFE4; border-color:#5C5648;}
  .btn-ghost:hover{border-color:var(--tan); color:var(--tan);}

  .banner-contact{
    display:flex; flex-wrap:wrap; border:1px solid rgba(201,168,118,0.4);
  }
  .banner-contact .item{
    padding:12px 18px; border-right:1px solid rgba(201,168,118,0.4);
    font-size:12.5px; flex:1; min-width:140px;
  }
  .banner-contact .item:last-child{border-right:none;}
  .banner-contact .label{font-family:'JetBrains Mono',monospace; font-size:9.5px; text-transform:uppercase; color:#8F887A; display:block; margin-bottom:2px;}
  .banner-contact .val{font-weight:600; color:#F4EFE4;}

  /* LIGHT SITE NAV (for scroll context on light sections) */
  .light-nav{position:sticky; top:0; z-index:50; background:rgba(250,248,243,0.9); backdrop-filter:blur(8px); border-bottom:1px solid var(--line); display:none;}

  section{padding:76px 0; border-top:1px solid var(--line-soft);}
  .section-head{margin-bottom:40px; max-width:60ch;}
  .section-head h2{font-size:30px; font-weight:800; margin-top:8px;}
  .section-num{
    display:inline-flex; align-items:center; justify-content:center;
    width:26px; height:26px; background:var(--ink); color:var(--bg);
    font-family:'JetBrains Mono',monospace; font-size:12px; margin-right:10px;
  }

  .services-grid{display:grid; grid-template-columns:repeat(3,1fr); border:1px solid var(--line); border-radius:2px; overflow:hidden;}
  .service-card{padding:28px 24px; border-right:1px solid var(--line); border-bottom:1px solid var(--line);}
  .services-grid .service-card:nth-child(3n){border-right:none;}
  .services-grid .service-card:nth-last-child(-n+3){border-bottom:none;}
  .service-icon{width:42px; height:42px; border:1.5px solid var(--ink); border-radius:50%; display:flex; align-items:center; justify-content:center; margin-bottom:16px; font-family:'JetBrains Mono',monospace;}
  .service-card h3{font-size:17px; font-weight:700; margin-bottom:8px;}
  .service-card p{font-size:13.5px; color:var(--ink-soft);}

  .process-row{display:flex; justify-content:space-between; position:relative; margin-top:10px;}
  .process-row::before{content:""; position:absolute; top:24px; left:5%; right:5%; height:1px; background:var(--line-soft); z-index:0;}
  .process-step{position:relative; z-index:1; text-align:center; flex:1; padding:0 6px;}
  .process-circle{width:50px; height:50px; margin:0 auto 14px; background:var(--bg); border:1.5px solid var(--ink); border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'JetBrains Mono',monospace; font-weight:600; font-size:14px;}
  .process-step h4{font-family:'Playfair Display',serif; font-size:16px; font-weight:700; margin-bottom:6px;}
  .process-step p{font-size:12.5px; color:var(--muted); max-width:18ch; margin:0 auto;}

  .project{position:relative; border:1px solid var(--line); padding:32px; margin-bottom:24px; display:grid; grid-template-columns:1fr 220px; gap:32px; align-items:center;}
  .project-badge{position:absolute; top:-1px; left:-1px; background:var(--ink); color:var(--bg); font-family:'JetBrains Mono',monospace; font-size:12px; font-weight:600; padding:6px 14px;}
  .project h3{font-size:24px; font-weight:800; margin:16px 0 10px;}
  .project p{color:var(--ink-soft); font-size:14.5px; max-width:56ch; margin-bottom:14px;}
  .tags{display:flex; flex-wrap:wrap; gap:8px; margin-bottom:14px;}
  .tag{font-family:'JetBrains Mono',monospace; font-size:11px; padding:5px 12px; border:1px solid var(--line); border-radius:20px; color:var(--ink-soft);}
  .feature-list{display:grid; grid-template-columns:1fr 1fr; gap:6px 20px;}
  .feature-list li{font-size:13px; color:var(--ink-soft); list-style:none; padding-left:14px; position:relative;}
  .feature-list li::before{content:"—"; position:absolute; left:0; color:var(--tan);}

  .phone{width:180px; height:366px; background:var(--ink); border-radius:28px; padding:7px; margin:0 auto; box-shadow:0 20px 40px -16px rgba(20,19,17,0.28);}
  .phone-screen{width:100%; height:100%; border-radius:22px; overflow:hidden; background:var(--panel); display:flex; flex-direction:column;}
  .screen-header{padding:14px 12px 8px; font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.06em; text-transform:uppercase;}
  .screen-body{padding:0 12px 12px; flex:1; display:flex; flex-direction:column; gap:6px;}
  .cru .screen-header{color:var(--ink);}
  .cru .block:nth-child(1){height:56px; background:var(--tan-soft);}
  .cru .block:nth-child(2){height:28px; background:var(--line-soft); width:70%;}
  .cru .block:nth-child(3){height:28px; background:var(--line-soft); width:90%;}
  .cru .block:nth-child(4){height:64px; background:var(--tan); margin-top:6px;}
  .lamp .screen-header{color:var(--ink);}
  .lamp .block:nth-child(1){height:86px; background:var(--tan-soft);}
  .lamp .block:nth-child(2){height:10px; background:var(--line-soft); width:85%;}
  .lamp .block:nth-child(3){height:10px; background:var(--line-soft); width:60%;}
  .lamp .block:nth-child(4){height:38px; background:var(--tan); margin-top:8px; border-radius:19px;}
  .block{border-radius:6px;}

  .stack-row{display:flex; flex-wrap:wrap; gap:10px;}
  .stack-pill{font-family:'JetBrains Mono',monospace; font-size:12.5px; font-weight:500; padding:9px 16px; border:1px solid var(--line); border-radius:20px;}

  .contact-panel{border:1px solid var(--line); background:var(--tan-soft); padding:48px 40px; text-align:center;}
  .contact-panel h2{font-size:32px; font-weight:800; margin-bottom:22px;}
  .contact-bar{display:flex; justify-content:center; flex-wrap:wrap; gap:0; border:1px solid var(--line); background:var(--bg); max-width:760px; margin:0 auto;}
  .contact-item{display:flex; flex-direction:column; align-items:center; gap:4px; padding:16px 24px; border-right:1px solid var(--line); font-size:13px; flex:1; justify-content:center;}
  .contact-item:last-child{border-right:none;}
  .contact-item .label{font-family:'JetBrains Mono',monospace; font-size:10px; text-transform:uppercase; color:var(--muted); display:block;}
  .contact-item .val{font-weight:600;}

  footer{background:var(--black); color:#D9D2C2; padding:48px 0 28px;}
  .footer-top{display:flex; justify-content:space-between; gap:40px; flex-wrap:wrap; padding-bottom:32px; border-bottom:1px solid rgba(201,168,118,0.25); margin-bottom:22px;}
  .footer-brand{display:flex; align-items:center; gap:12px;}
  .footer-brand img{height:32px; width:auto;}
  .footer-brand span{font-family:'Playfair Display',serif; font-weight:700; font-size:18px; color:#F4EFE4;}
  .footer-cols{display:flex; gap:56px; flex-wrap:wrap;}
  .footer-col h5{font-family:'JetBrains Mono',monospace; font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:var(--tan); margin-bottom:12px;}
  .footer-col a{display:block; font-size:13.5px; color:#D9D2C2; margin-bottom:8px; transition:color 0.15s;}
  .footer-col a:hover{color:var(--tan);}
  .footer-bottom{display:flex; justify-content:space-between; font-size:12px; color:#8F887A; flex-wrap:wrap; gap:10px;}

  @media (max-width:820px){
    .banner-body{grid-template-columns:1fr; text-align:center;}
    .banner-photo{order:-1;}
    
    .banner-nav{display:none;}
    .banner-cta{justify-content:center;}
    .banner-contact{flex-direction:column;}
    .banner-contact .item{border-right:none; border-bottom:1px solid rgba(201,168,118,0.4);}
    .banner-contact .item:last-child{border-bottom:none;}
    .services-grid{grid-template-columns:1fr;}
    .services-grid .service-card{border-right:none;}
    .services-grid .service-card:nth-last-child(-n+3){border-bottom:1px solid var(--line);}
    .services-grid .service-card:last-child{border-bottom:none;}
    .process-row{flex-wrap:wrap; gap:24px 0;}
    .process-row::before{display:none;}
    .process-step{flex:0 0 50%;}
    .project{grid-template-columns:1fr;}
    .phone{order:-1;}
    .feature-list{grid-template-columns:1fr;}
    .contact-bar{flex-direction:column;}
    .contact-item{border-right:none; border-bottom:1px solid var(--line); justify-content:flex-start;}
    .contact-item:last-child{border-bottom:none;}
    .footer-cols{gap:32px;}
  }
  @media (prefers-reduced-motion:reduce){ html{scroll-behavior:auto;} *{transition:none !important;} }
</style>
</head>
